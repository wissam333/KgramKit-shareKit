          <span class="rcd-code">{{ roomId }}</span>
        </div>
      </div>
    </SharedUiDialogAppModal>

    <!-- ── CONNECTING OVERLAY ────────────────────────────────────── -->
    <div v-if="room.status.value === 'loading'" class="connecting-overlay">
      <div class="conn-card">
        <Icon name="mdi:loading" size="30" class="spin" />
        <span>{{ $t("connectingToRoom") }}</span>
      </div>
    </div>
