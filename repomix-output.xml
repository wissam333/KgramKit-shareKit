          </span>
        </button>
      </template>

      <!-- Theme panel trigger -->
      <div class="navbar-theme-wrapper">
        <button
          class="action-btn"
          title="Theme"
          @click="isThemePanelOpen = !isThemePanelOpen"
        >
          <Icon name="mdi:palette-outline" size="19" />
        </button>

        <Transition name="panel-slide">
          <div
