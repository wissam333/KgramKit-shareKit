            variant="outline"
            @click="showLogoutModal = false"
          >
            {{ $t("cancel") }}
          </SharedUiButtonBase>
          <SharedUiButtonBase
            variant="error"
            icon-left="mdi:logout"
            :loading="isLoggingOut"
            @click="handleLogout"
          >
            {{ $t("logout") }}
          </SharedUiButtonBase>
