              {{ m.name.charAt(0).toUpperCase() }}
            </div>
            <span class="sm-name">{{ m.isMe ? $t("you") : m.name }}</span>
            <Icon
              v-if="m.peerId === remoteSharerId || (m.isMe && isSharingLocally)"
              name="mdi:monitor-share"
