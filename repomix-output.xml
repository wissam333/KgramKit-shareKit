              v-for="(count, h) in result.byHour"
              :key="h"
              class="hour-bar-wrap"
              :title="`${h}:00 — ${count} msgs`"
            >
              <div
                class="hour-bar"
                :style="{ height: `${barHeight(count)}%` }"
                :class="{ peak: h === result.peakHour }"
              />
              <div class="hour-label">{{ h % 3 === 0 ? h : "" }}</div>
            </div>
          </div>
