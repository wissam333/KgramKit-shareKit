  }
  @media (max-width: 480px) {
    min-height: 220px;
  }
}

/* ─── Side / share ───────────────────────────────────── */
.draw-side {
  grid-column: 2 / 3;
  grid-row: 1 / 3;
  display: flex;
  flex-direction: column;
  gap: 10px;

  @media (max-width: 700px) {
    grid-column: 1 / -1;
    grid-row: auto;
  }
}
