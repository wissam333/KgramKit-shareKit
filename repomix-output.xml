<script setup>
import { ref, onMounted, onUnmounted } from "vue";

const { locale, setLocale } = useI18n();
const { isDark, toggleDark, init } = useTheme();

const isScrolled = ref(false);

const toggleLang = () => {
  setLocale(locale.value === "ar" ? "en" : "ar");
};

const onScroll = () => {
  isScrolled.value = window.scrollY > 12;
};

onMounted(() => {
