  showBack: { type: Boolean, default: false },
  backTo: { type: String, default: "" },
  isRtl: { type: Boolean, default: false },
  actions: { type: Array, default: () => [] },
});

const emit = defineEmits(["back", "action-click"]);
const router = useRouter();

const handleBack = () => {
